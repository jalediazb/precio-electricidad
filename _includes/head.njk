<!DOCTYPE html><html lang="es" data-theme="light" class="has-navbar-fixed-bottom">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css">
        <link rel="stylesheet" href="//cdn.jsdelivr.net/chartist.js/latest/chartist.min.css">
        <link rel="stylesheet" href="/_includes/style.css">
        <script src="//cdn.jsdelivr.net/chartist.js/latest/chartist.min.js"></script>
        <title>{{ title }}</title>
        <meta name="description" content="{{ meta_description }}">
        {% if robots %}
        <meta name="robots" content="{{ robots }}">
        {% endif %}
        <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebPage",
            "name": "{{ title }}",
            "description": "{{ meta_description }}",
            "url": "{{ page.url }}"
        }
        </script>
        <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3360355213948178" crossorigin="anonymous"></script>
        
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website">
        <meta property="og:url" content="https://electon.es{{ page.url }}">
        <meta property="og:title" content="{{ title }}">
        <meta property="og:description" content="{{ meta_description }}">
        {% if og_image %}
        <meta property="og:image" content="https://electon.es{{ og_image }}">
        {% else %}
        <meta property="og:image" content="https://electon.es/img/comprar-precio-electricidad-espana.jpg">
        {% endif %}
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
        <meta property="og:locale" content="es_ES">
        <meta property="og:site_name" content="ElectON">
        
        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image">
        <meta property="twitter:url" content="https://electon.es{{ page.url }}">
        <meta property="twitter:title" content="{{ title }}">
        <meta property="twitter:description" content="{{ meta_description }}">
        {% if og_image %}
        <meta property="twitter:image" content="https://electon.es{{ og_image }}">
        {% else %}
        <meta property="twitter:image" content="https://electon.es/img/comprar-precio-electricidad-espana.jpg">
        {% endif %}
    </head>
    <body>
