---
title: Precio Electricidad
---

{% include "_includes/head.njk" %}
{% include "_includes/header.njk" %}
<main>
    <!-- Hero Section Mejorado -->
    <section class="hero-new">
        <div class="hero-new-container">
            <div class="hero-new-content">
                <div class="hero-badge">⚡ Datos actualizados</div>
                <h1 class="hero-title">Precio de la Luz Hoy en España</h1>
                <p class="hero-subtitle">Consulta el precio de la electricidad por horas en el mercado regulado (PVPC). Ahorra hasta un 40% en tu factura programando tus electrodomésticos en las horas más baratas.</p>
                <div class="hero-date">
                    <span class="date-icon">📅</span>
                    <span class="date-text">{{ precios.fecha }}</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Gráfico y Quick Facts - Layout Mejorado -->
    <section class="chart-section">
        <div class="container">
            <div class="chart-layout">
                <!-- Columna Principal: Gráfico -->
                <div class="chart-main">
                    <div class="chart-card">
                        <header class="chart-header">
                            <h2 class="chart-title">📈 Evolución horaria del precio PVPC</h2>
                            <span class="chart-subtitle">Precio del kWh por hora del día</span>
                        </header>
                        <div class="chart-body">
                            <div class="ct-chart ct-perfect-fourth"></div>
                        </div>
                    </div>
                </div>

                <!-- Columna Lateral: Quick Facts -->
                <div class="chart-sidebar">
                    <div class="quick-facts-panel">
                        <h3 class="quick-facts-title">💡 Datos clave de hoy</h3>
                        
                        <div class="quick-fact-box cheap">
                            <div class="quick-fact-icon">🌙</div>
                            <div class="quick-fact-label">Hora más barata</div>
                            <div class="quick-fact-value" id="fact-cheapest-hour">--</div>
                            <div class="quick-fact-hint">Ideal para lavadora y lavavajillas</div>
                        </div>

                        <div class="quick-fact-box expensive">
                            <div class="quick-fact-icon">⚠️</div>
                            <div class="quick-fact-label">Hora más cara</div>
                            <div class="quick-fact-value" id="fact-expensive-hour">--</div>
                            <div class="quick-fact-hint">Evita electrodomésticos</div>
                        </div>

                        <div class="quick-fact-box average">
                            <div class="quick-fact-icon">📊</div>
                            <div class="quick-fact-label">Precio medio</div>
                            <div class="quick-fact-value" id="fact-average-price">--</div>
                            <div class="quick-fact-hint">Referencia del día</div>
                        </div>

                        <a href="/horas-mas-baratas-luz-hoy/" class="quick-facts-cta">
                            Ver horas más baratas →
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Franjas Horarias -->
    <div id="contenedor-franjas"></div>

    <!-- Contenido Principal -->
    <section class="content-section-main">
        <div class="container content is-medium home-content">
            {{ content | safe }}
        </div>
    </section>
</main>
{% include "_includes/footer.njk" %}
